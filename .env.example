# --- App (usuario único) ---
PUBLIC_BASE_URL=http://localhost:4321
# Password de acceso a la app (única cuenta; sin registro).
APP_PASSWORD=
# Secreto para firmar la cookie de sesión.
SESSION_SECRET=cambia-esto-por-una-cadena-aleatoria-larga
DATABASE_PATH=./data/app.db

# --- Claude (Fase 3) ---
ANTHROPIC_API_KEY=

# --- Meta / Instagram (Fase 2) ---
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4321/api/instagram/callback

# --- Cloudflare R2 (Fase 5) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=insta-bot-media

# --- Gestor del portafolio (javiersabando.lat) ---
# Misma URI que el MONGODB_URI del portfolio (db rtp_blog en la URI).
PORTFOLIO_MONGODB_URI=
# Bucket R2 PÚBLICO del portfolio (distinto de insta-bot-media, que es privado).
PORTFOLIO_R2_ACCOUNT_ID=
PORTFOLIO_R2_ACCESS_KEY_ID=
PORTFOLIO_R2_SECRET_ACCESS_KEY=
PORTFOLIO_R2_BUCKET=
PORTFOLIO_ASSETS_BASE_URL=https://javiersabando.lat
