---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "InstaCaptions" } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-neutral-50 text-neutral-900 antialiased">
    <header class="border-b border-neutral-200 bg-white">
      <nav
        class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3"
      >
        <a href={user ? "/app" : "/"} class="text-lg font-semibold tracking-tight">
          Insta<span class="text-pink-600">Captions</span>
        </a>
        {
          user ? (
            <div class="flex items-center gap-4 text-sm">
              <a href="/app" class="text-neutral-600 hover:text-neutral-900">
                Panel
              </a>
              <a
                href="/app/settings"
                class="text-neutral-600 hover:text-neutral-900"
              >
                Ajustes
              </a>
            </div>
          ) : (
            <div class="flex items-center gap-3 text-sm">
              <a href="/login" class="text-neutral-600 hover:text-neutral-900">
                Entrar
              </a>
              <a
                href="/register"
                class="rounded-lg bg-neutral-900 px-3 py-1.5 font-medium text-white hover:bg-neutral-700"
              >
                Crear cuenta
              </a>
            </div>
          )
        }
      </nav>
    </header>
    <main class="mx-auto w-full max-w-3xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
