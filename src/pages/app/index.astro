---
import Layout from "../../layouts/Layout.astro";

const user = Astro.locals.user!;

const cards = [
  {
    href: "/app/posts",
    title: "Mis publicaciones",
    description: "Genera captions para tus últimos posts de Instagram.",
    ready: true,
  },
  {
    href: "/app/new",
    title: "Nueva publicación",
    description:
      "Sube una o varias fotos (carrusel), genera el caption y publica o programa.",
    ready: true,
  },
  {
    href: "/app/feed",
    title: "Planifica tu feed",
    description:
      "Arrastra y ordena tus próximas fotos sobre tu feed actual y prográmalas.",
    ready: true,
  },
  {
    href: "/app/scheduled",
    title: "Programadas",
    description: "Revisa, cancela o reintenta tus publicaciones en cola.",
    ready: true,
  },
  {
    href: "/app/library",
    title: "Biblioteca",
    description: "Tus imágenes organizadas en carpetas.",
    ready: true,
  },
  {
    href: "/app/settings",
    title: "Ajustes",
    description: "Conecta tu cuenta de Instagram y gestiona tu sesión.",
    ready: true,
  },
];
---

<Layout title="Panel — InstaCaptions">
  <h1 class="mb-1 text-2xl font-bold">Hola, {user.name}</h1>
  <p class="mb-8 text-neutral-600">¿Qué quieres hacer hoy?</p>

  <div class="grid gap-4 sm:grid-cols-2">
    {
      cards.map((card) =>
        card.ready ? (
          <a
            href={card.href}
            class="rounded-xl border border-neutral-200 bg-white p-5 transition hover:border-pink-300 hover:shadow-sm"
          >
            <h2 class="font-semibold">{card.title}</h2>
            <p class="mt-1 text-sm text-neutral-600">{card.description}</p>
          </a>
        ) : (
          <div class="rounded-xl border border-dashed border-neutral-300 bg-neutral-50 p-5 opacity-70">
            <h2 class="font-semibold">
              {card.title}
              <span class="ml-2 rounded-full bg-neutral-200 px-2 py-0.5 text-xs font-medium text-neutral-600">
                Próximamente
              </span>
            </h2>
            <p class="mt-1 text-sm text-neutral-600">{card.description}</p>
          </div>
        ),
      )
    }
  </div>
</Layout>
