---
// Gestor de imágenes del portafolio (javiersabando.lat). La app es de un solo
// usuario: cualquier sesión válida es el dueño.
import Layout from "../../layouts/Layout.astro";
import PortfolioManager from "../../components/vue/PortfolioManager.vue";
---

<Layout title="Portafolio — InstaCaptions">
  <h1 class="mb-2 text-2xl font-bold">Portafolio</h1>
  <p class="mb-8 text-sm text-neutral-600">
    Imágenes de <span class="font-medium">javiersabando.lat</span>: sube fotos
    (se convierten a WebP), genera la metadata bilingüe con IA y publícalas en
    la galería.
  </p>
  <PortfolioManager client:load />
</Layout>
