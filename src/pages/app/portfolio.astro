---
// Gestor de imágenes del portafolio (javiersabando.lat). La app es de un solo
// usuario: cualquier sesión válida es el dueño.
import Layout from "../../layouts/Layout.astro";
import PortfolioManager from "../../components/vue/PortfolioManager.vue";
---

<Layout title="Portafolio — InstaCaptions">
  <div class="mb-2 flex items-center justify-between gap-3">
    <h1 class="text-2xl font-bold">Portafolio</h1>
    <div class="flex items-center gap-2">
      <a
        href="/app/portfolio/blogs"
        class="rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-medium text-neutral-700 hover:bg-neutral-100"
      >
        📝 Posts
      </a>
      <a
        href="/app/portfolio/tags"
        class="rounded-lg border border-neutral-300 px-3 py-1.5 text-sm font-medium text-neutral-700 hover:bg-neutral-100"
      >
        🏷️ Vocabulario
      </a>
      <a
        href="/app/portfolio/revisar"
        class="rounded-lg bg-pink-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-pink-500"
      >
        ⚡ Revisar (modo teclado)
      </a>
    </div>
  </div>
  <p class="mb-8 text-sm text-neutral-600">
    Imágenes de <span class="font-medium">javiersabando.lat</span>: sube fotos
    (se convierten a WebP), genera la metadata bilingüe con IA y publícalas en
    la galería.
  </p>
  <PortfolioManager client:load />
</Layout>
