---
import Layout from "../../layouts/Layout.astro";
import UploadForm from "../../components/vue/UploadForm.vue";
---

<Layout title="Nueva publicación — InstaCaptions">
  <h1 class="mb-1 text-2xl font-bold">Nueva publicación</h1>
  <p class="mb-6 text-neutral-600">
    Sube una o varias fotos (hasta 10 para un carrusel), deja que Claude escriba
    el caption y publícala al instante o prográmala para más tarde.
  </p>
  <UploadForm client:load />
</Layout>
