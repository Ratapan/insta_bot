---
import Layout from "../layouts/Layout.astro";
import AuthForm from "../components/vue/AuthForm.vue";
---

<Layout title="Entrar — InstaCaptions">
  <section class="mx-auto max-w-sm py-8">
    <h1 class="mb-6 text-2xl font-bold">Entrar</h1>
    <AuthForm client:load mode="login" />
    <p class="mt-4 text-sm text-neutral-600">
      ¿No tienes cuenta?
      <a href="/register" class="font-medium text-pink-600 hover:underline">
        Regístrate
      </a>
    </p>
  </section>
</Layout>
