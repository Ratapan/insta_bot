---
// Login de usuario único: una sola password (APP_PASSWORD). El middleware
// redirige aquí a cualquier petición de página sin sesión, y a /app si ya
// hay sesión.
import Layout from "../layouts/Layout.astro";
---

<Layout title="Entrar — InstaCaptions">
  <section class="mx-auto max-w-sm py-8">
    <h1 class="mb-6 text-2xl font-bold">Entrar</h1>
    <form id="login-form" class="space-y-4">
      <div>
        <label for="password" class="mb-1 block text-sm font-medium">
          Contraseña
        </label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autofocus
          autocomplete="current-password"
          class="w-full rounded-lg border border-neutral-300 px-3 py-2 text-sm focus:border-pink-500 focus:outline-none"
        />
      </div>
      <p
        id="login-error"
        class="hidden rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700"
      >
      </p>
      <button
        id="login-submit"
        type="submit"
        class="w-full rounded-lg bg-neutral-900 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-700 disabled:opacity-50"
      >
        Entrar
      </button>
    </form>
  </section>
</Layout>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const errorEl = document.getElementById("login-error") as HTMLParagraphElement;
  const submitEl = document.getElementById("login-submit") as HTMLButtonElement;

  const MESSAGES: Record<string, string> = {
    invalid_password: "Contraseña incorrecta.",
    rate_limited: "Demasiados intentos. Espera 15 minutos.",
    not_configured: "Falta APP_PASSWORD en el servidor.",
  };

  form.addEventListener("submit", async (event) => {
    event.preventDefault();
    errorEl.classList.add("hidden");
    submitEl.disabled = true;
    submitEl.textContent = "Entrando…";
    try {
      const password = new FormData(form).get("password");
      const res = await fetch("/api/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ password }),
      });
      if (res.ok) {
        window.location.href = "/app";
        return;
      }
      const data = await res.json().catch(() => ({}));
      errorEl.textContent =
        MESSAGES[data.error] ?? "Algo ha ido mal. Inténtalo de nuevo.";
      errorEl.classList.remove("hidden");
    } catch {
      errorEl.textContent = "Algo ha ido mal. Inténtalo de nuevo.";
      errorEl.classList.remove("hidden");
    } finally {
      submitEl.disabled = false;
      submitEl.textContent = "Entrar";
    }
  });
</script>
