---
import Layout from "../layouts/Layout.astro";
import AuthForm from "../components/vue/AuthForm.vue";
---

<Layout title="Crear cuenta — InstaCaptions">
  <section class="mx-auto max-w-sm py-8">
    <h1 class="mb-6 text-2xl font-bold">Crear cuenta</h1>
    <AuthForm client:load mode="register" />
    <p class="mt-4 text-sm text-neutral-600">
      ¿Ya tienes cuenta?
      <a href="/login" class="font-medium text-pink-600 hover:underline">
        Entra
      </a>
    </p>
  </section>
</Layout>
